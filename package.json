{
  "name": "vitepress-project",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/parse-resources.js && node scripts/build-search-index.js && vitepress dev docs",
    "generate-atom": "node scripts/generate-atom.js",
    "build": "node scripts/parse-resources.js && node scripts/build-search-index.js && vitepress build docs",
    "serve": "vitepress serve docs",
    "fetch-commits": "node scripts/fetch-commits.js",
    "build:search": "pagefind --site docs/.vitepress/dist --output-path docs/.vitepress/dist/pagefind",
    "prebuild": "npm run generate-atom",
    "postbuild": "npm run build:search && npm run replace:turnstile",
    "sync": "node scripts/sync-content.js",
    "replace:turnstile": "node -e \"const fs=require('fs');const key=process.env.TURNSTILE_SITE_KEY||'TURNSTILE_PLACEHOLDER';const d='docs/.vitepress/dist';fs.readdirSync(d).forEach(f=>{if(f.endsWith('.html')){const path=d+'/'+f;const c=fs.readFileSync(path,'utf8');if(c.includes('TURNSTILE_PLACEHOLDER')){fs.writeFileSync(path,c.replace(/TURNSTILE_PLACEHOLDER/g,key));console.log('Replaced in',path)}}})\""
  },
  "devDependencies": {
    "@pagefind/default-ui": "^1.5.0",
    "node-fetch": "^3.3.2",
    "pagefind": "^1.5.0",
    "vitepress": "1.0.0",
    "vue": "3.2.44"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1",
    "flexsearch": "^0.8.205",
    "fuse.js": "^6.6.2",
    "markdown-it": "^14.1.0",
    "qrcode": "^1.5.4"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search"
      ]
    }
  }
}

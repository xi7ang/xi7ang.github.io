{
  "name": "vitepress-project",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vitepress build docs && pagefind --site docs/.vitepress/dist --output-path docs/.vitepress/dist/pagefind",
    "serve": "vitepress serve docs",
    "fetch-commits": "node scripts/fetch-commits.js",
    "postbuild": "pagefind --site docs/.vitepress/dist --output-path docs/.vitepress/dist/pagefind"
  },
  "devDependencies": {
    "@pagefind/default-ui": "^1.5.0",
    "node-fetch": "^3.3.2",
    "pagefind": "^1.5.0",
    "vitepress": "1.0.0",
    "vue": "3.2.44"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1",
    "flexsearch": "^0.8.205",
    "markdown-it": "^14.1.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search"
      ]
    }
  }
}

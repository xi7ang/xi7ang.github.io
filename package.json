{
  "name": "vitepress-project",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/parse-resources.js && node scripts/build-search-index.js && vitepress dev docs",
    "generate-atom": "node scripts/generate-atom.js",
    "build": "node scripts/parse-resources.js && node scripts/build-search-index.js && vitepress build docs",
    "serve": "vitepress serve docs",
    "fetch-commits": "node scripts/fetch-commits.js",
    "build:search": "pagefind --site docs/.vitepress/dist --output-path docs/.vitepress/dist/pagefind",
    "prebuild": "npm run generate-atom",
    "postbuild": "npm run build:search",
    "sync": "node scripts/sync-content.js"
  },
  "devDependencies": {
    "@pagefind/default-ui": "^1.5.0",
    "node-fetch": "^3.3.2",
    "pagefind": "^1.5.0",
    "vitepress": "1.0.0",
    "vue": "3.2.44"
  },
  "dependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.60.1",
    "flexsearch": "^0.8.205",
    "fuse.js": "^6.6.2",
    "markdown-it": "^14.1.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@algolia/client-search"
      ]
    }
  }
}
